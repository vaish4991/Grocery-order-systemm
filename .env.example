# ============================================================
# GOS — Grocery Ordering System
# Environment Variables Reference
# ============================================================
# Copy this file to .env in each app directory and fill in real values.
# apps/api/.env
# apps/web/.env.local
# apps/admin/.env.local

# ------------------------------------------------------------
# API — NestJS Backend
# ------------------------------------------------------------

# App
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database — PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=gos_db

# Cache — Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_TTL_SECONDS=300

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=gos-grocery-bucket

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (SMTP / SES)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="GOS Grocery <noreply@gosgrocery.com>"

# SMS (MSG91)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=GOSCRY
MSG91_TEMPLATE_ID=your_otp_template_id

# Admin
ADMIN_EMAIL=admin@gosgrocery.com
ADMIN_PASSWORD=Admin@123!

# ------------------------------------------------------------
# Web — Customer Next.js App
# ------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Admin — Admin Next.js App
# ------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3001
